# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js
/.next/
/out/
next-env.d.ts

# Production
/build
/dist

# Environment
.env
.env*.local
.env.production

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Rust / Soroban (build outputs only; circuit wasm under circuits/ is committed)
contracts/target/
contracts/**/target/
Cargo.lock

# ZK circuits — ignore large/regenerable setup artifacts and test outputs.
# The RUNTIME artifacts (witness wasm, final zkey, verification key) ARE
# committed so the deployed app and the on-chain verifier work without a rebuild.
circuits/**/*.r1cs
circuits/**/*.sym
circuits/**/*.wtns
circuits/**/*.ptau
circuits/**/*_0.zkey
circuits/**/input*.json
circuits/**/proof*.json
circuits/**/public*.json

# Generated receipts / PDFs
/tmp
*.pdf
!docs/**/*.pdf

# Coverage / tests
/coverage

# Local tool binaries (e.g. downloaded circom)
/tools

# Local working notes / scratch (not versioned)
/temp
