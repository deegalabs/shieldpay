# ─────────────────────────────────────────────────────────────
# ShieldPay — Environment Variables (example)
# Copy to .env.local for development. NEVER commit real secrets.
# On Railway, set these in the service "Variables" tab.
# ─────────────────────────────────────────────────────────────

# ── Stellar network ──────────────────────────────────────────
# Options: testnet | mainnet
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# USDC asset (Circle testnet issuer). Replace issuer for mainnet.
USDC_ASSET_CODE=USDC
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ── Deployed Soroban contract IDs (filled in after deploy) ───
ANCHOR_REGISTRY_CONTRACT_ID=
PAYMENT_VERIFIER_CONTRACT_ID=

# ── Company paying wallet (server-side signer for the demo) ──
# In production this is a wallet signature flow, not a stored secret.
# For the hackathon demo we sign server-side from a funded testnet key.
COMPANY_SECRET_KEY=
COMPANY_PUBLIC_KEY=

# ── Database (Railway Postgres) ──────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/shieldpay

# ── Auth ─────────────────────────────────────────────────────
# Secret used to sign our session JWTs (and auditor/magic links).
JWT_SECRET=change-me-in-production

# Optional: encrypts the company viewing key at rest in Postgres. If unset, the
# viewing key is stored as plaintext (current behavior). Set any strong secret to
# enable; existing rows keep working and are re-encrypted on next write.
VIEWING_KEY_ENC_KEY=

# Privy (seedless login: email / Google / passkey). Create an app at privy.io,
# then add your domains under Allowed domains. App secret is server-side only.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public explorer base used in receipts/QR codes
NEXT_PUBLIC_STELLAR_EXPLORER=https://stellar.expert/explorer/testnet
