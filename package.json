{
  "name": "shieldpay",
  "version": "0.1.0",
  "private": true,
  "description": "Payroll & Payment Proof on Stellar + ZK — pay anyone, prove it mathematically, protect your company forever.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "zk:setup": "bash circuits/scripts/setup.sh",
    "zk:prove": "tsx circuits/scripts/generate_proof.ts",
    "contracts:build": "bash contracts/deploy/build.sh",
    "contracts:deploy": "bash contracts/deploy/deploy.sh",
    "seed": "tsx scripts/seed.ts",
    "test:flow": "tsx scripts/test_flow.ts"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.31.0",
    "@privy-io/server-auth": "^1.32.5",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@simplewebauthn/browser": "^10.0.0",
    "@simplewebauthn/server": "^10.0.1",
    "@stellar/freighter-api": "^3.0.0",
    "@stellar/stellar-sdk": "^15.1.0",
    "clsx": "^2.1.1",
    "jose": "^5.6.3",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.417.0",
    "next": "^14.2.5",
    "papaparse": "^5.4.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "snarkjs": "^0.7.4",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.40",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
