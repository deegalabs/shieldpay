# Normalize line endings to LF across platforms
* text=auto eol=lf

# Shell scripts must be LF (run on Linux CI / Railway)
*.sh text eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.pdf binary
*.wasm binary
*.zkey binary
*.ptau binary
